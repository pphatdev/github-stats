<header class="border-b border-slate-800 bg-card-dark" role="banner">
    <nav class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between" aria-label="Main navigation">
        <div class="flex items-center gap-3">
            <a href="/" class="w-10 h-10 flex items-center justify-center bg-primary rounded-xl text-white hover:bg-primary/90 transition-colors" aria-label="GitHub Stats Home">
                <img src="https://pphat.top/assets/logo/logo-transparent-dark-mode.png" alt="GitHub Stats Logo" width="32" height="32" class="w-8 h-8"/>
            </a>
            <div>
                <h1 class="text-xl font-bold text-white">GitHub Stats</h1>
                <p class="text-sm <%= typeof username !== 'undefined' ? 'text-slate-400' : 'text-blue-100' %>">
                    <%= typeof username !== 'undefined' ? '@' + username : 'Generate dynamic stat cards' %>
                </p>
            </div>
        </div>
        <!-- Actions -->
        <div class="flex items-center gap-3">
            <a href="https://github.com/pphatdev/github-stats" target="_blank" rel="noopener noreferrer" class="hidden sm:flex items-center gap-2 bg-slate-800 hover:bg-slate-700 text-white px-4 py-2 rounded-lg transition-colors font-medium text-sm" aria-label="Star this project on GitHub">
                <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor">
                    <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"></path>
                </svg>
                <span>Star</span>
            </a>
            <a href="<%= typeof username !== 'undefined' ? 'https://github.com/' + username : 'https://github.com/pphatdev' %>" target="_blank" rel="noopener noreferrer" class="<%= typeof username !== 'undefined' ? 'text-slate-400 hover:text-slate-200' : 'text-blue-100 hover:text-white' %>" aria-label="<%= typeof username !== 'undefined' ? 'Visit ' + username + ' on GitHub' : 'Visit pphatdev on GitHub' %>">
                <svg aria-hidden="true" focusable="false" class="size-8" viewBox="0 0 24 24" width="32" height="32" fill="currentColor" display="inline-block" overflow="visible" style="vertical-align:text-bottom"><path d="M12 1C5.923 1 1 5.923 1 12c0 4.867 3.149 8.979 7.521 10.436.55.096.756-.233.756-.522 0-.262-.013-1.128-.013-2.049-2.764.509-3.479-.674-3.699-1.292-.124-.317-.66-1.293-1.127-1.554-.385-.207-.936-.715-.014-.729.866-.014 1.485.797 1.691 1.128.99 1.663 2.571 1.196 3.204.907.096-.715.385-1.196.701-1.471-2.448-.275-5.005-1.224-5.005-5.432 0-1.196.426-2.186 1.128-2.956-.111-.275-.496-1.402.11-2.915 0 0 .921-.288 3.024 1.128a10.193 10.193 0 0 1 2.75-.371c.936 0 1.871.123 2.75.371 2.104-1.43 3.025-1.128 3.025-1.128.605 1.513.221 2.64.111 2.915.701.77 1.127 1.747 1.127 2.956 0 4.222-2.571 5.157-5.019 5.432.399.344.743 1.004.743 2.035 0 1.471-.014 2.654-.014 3.025 0 .289.206.632.756.522C19.851 20.979 23 16.854 23 12c0-6.077-4.922-11-11-11Z"></path></svg>
            </a>
        </div>
    </nav>
</header>
