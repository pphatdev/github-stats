{
    "version": 2,
    "framework": null,
    "functions": {
        "api/index.ts": {
            "maxDuration": 30
        }
    },
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/api/index"
        }
    ],
    "env": {
        "DATABASE_PROVIDER": "cloudflare"
    }
}
