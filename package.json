{
  "name": "github-stats",
  "version": "2.0.0",
  "description": "Generate dynamic GitHub stats cards for your README",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "node --watch --no-warnings=ExperimentalWarning --loader ts-node/esm ./src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio --host 127.0.0.1"
  },
  "keywords": [
    "github",
    "stats",
    "readme",
    "svg",
    "card"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@octokit/rest": "^20.0.2",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^4.18.2",
    "gifencoder": "^2.0.1",
    "node-fetch": "^3.3.2",
    "pngjs": "^7.0.0",
    "sharp": "^0.33.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/pngjs": "^6.0.5",
    "drizzle-kit": "^0.31.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
