<%- include('../partials/header.ejs') %>

<main class="max-w-7xl mx-auto px-6 py-12">
    <!-- Stats Card Display -->
    <div class="bg-card-dark rounded-4xl p-8 border border-slate-800 shadow-xl mb-8">
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-2xl font-bold text-white">GitHub Statistics</h2>
            <a href="/" class="text-primary hover:text-primary/80 flex items-center gap-2 text-sm font-semibold">
                <span class="material-icons-outlined text-lg">arrow_back</span>
                Back to Home
            </a>
        </div>
        <form id="customizeForm" class="space-y-4 my-6">
            <div class="flex gap-4 flex-wrap">
                <label class="flex items-center gap-2 cursor-pointer">
                    <input type="checkbox" name="hide_title" class="rounded border-slate-600" <%= hideTitle ? 'checked' : '' %>>
                    <span class="text-sm text-slate-300">Hide Title</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                    <input type="checkbox" name="hide_rank" class="rounded border-slate-600" <%= hideRank ? 'checked' : '' %>>
                    <span class="text-sm text-slate-300">Hide Rank</span>
                </label>
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-300 mb-3">Avatar Mode</label>
                <div class="flex gap-6 flex-wrap">
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="radio" name="avatar_mode" value="none" class="rounded border-slate-600" <%= avatarMode === 'none' ? 'checked' : '' %>>
                        <span class="text-sm text-slate-300">None</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="radio" name="avatar_mode" value="avatar" class="rounded border-slate-600" <%= avatarMode === 'avatar' ? 'checked' : '' %>>
                        <span class="text-sm text-slate-300">Show Avatar</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="radio" name="avatar_mode" value="radar" class="rounded border-slate-600" <%= avatarMode === 'radar' ? 'checked' : '' %>>
                        <span class="text-sm text-slate-300">Show Radar</span>
                    </label>
                </div>
            </div>
            <div class="grid md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-semibold text-slate-300 mb-2">Data Border Style</label>
                    <select name="data_border_style" class="w-full px-4 py-2 rounded-lg bg-slate-800 border border-slate-700 text-white">
                        <option value="solid" <%= dataBorderStyle === 'solid' ? 'selected' : '' %>>Solid</option>
                        <option value="frame" <%= dataBorderStyle === 'frame' ? 'selected' : '' %>>Frame</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-300 mb-2">Frame Position</label>
                    <select name="data_border_frame" class="w-full px-4 py-2 rounded-lg bg-slate-800 border border-slate-700 text-white">
                        <option value="out" <%= dataBorderFramePosition === 'out' ? 'selected' : '' %>>Outside</option>
                        <option value="in" <%= dataBorderFramePosition === 'in' ? 'selected' : '' %>>Inside</option>
                    </select>
                </div>
            </div>
            <div class="grid md:grid-cols-3 gap-4">
                <div>
                    <label class="block text-sm font-semibold text-slate-300 mb-2">Theme</label>
                    <select name="theme" class="w-full px-4 py-2 rounded-lg bg-slate-800 border border-slate-700 text-white">
                        <% themes.forEach(function(themeName) { %>
                            <option value="<%= themeName %>" <%= theme === themeName ? 'selected' : '' %>>
                                <%= themeName.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ') %>
                            </option>
                        <% }); %>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-300 mb-2">Custom Title</label>
                    <input type="text" name="custom_title" placeholder="My GitHub Stats" class="w-full px-4 py-2 rounded-lg bg-slate-800 border border-slate-700 text-white" value="<%= customTitle || '' %>"/>
                </div>
                <div class="grid">
                    <label class="block text-sm font-semibold text-slate-300 mb-2 invisible">Custom Title</label>
                    <button type="submit" class="bg-primary w-full hover:bg-primary/90 text-white font-semibold px-6 py-2 rounded-xl transition-colors">
                        Update Preview
                    </button>
                </div>
            </div>
        </form>
        <div id="imagePreview" class="bg-slate-900 rounded-2xl p-8 flex items-center justify-center relative">
            <img id="statsImage" src="<%= svgUrl %>" alt="GitHub Stats - <%= username %>" class="w-full" style="opacity: 0; transition: opacity 0.3s ease-in-out;"/>
            <div id="loadingOverlay" class="absolute inset-0 bg-slate-900/90 rounded-2xl flex items-center justify-center">
                <div class="text-center">
                    <svg class="animate-spin h-12 w-12 text-primary mx-auto mb-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    <p class="text-slate-300 font-semibold">Loading preview...</p>
                </div>
            </div>
        </div>

    </div>

    <!-- Embed Code Section -->
    <div class="bg-card-dark rounded-4xl p-8 border border-slate-800 shadow-xl mb-8">
        <h3 class="text-xl font-bold text-white mb-4">Embed This Card</h3>
        <p class="text-slate-400 mb-6">Copy this code to add it to your GitHub README</p>

        <div class="space-y-4">
            <div>
                <label class="block text-sm font-semibold text-slate-300 mb-2">Markdown</label>
                <div class="bg-slate-950 rounded-xl p-4 overflow-x-auto relative group">
                    <code class="text-sm text-blue-400 font-mono" id="markdown-code">![GitHub Stats](<%= fullUrl %>)</code>
                    <button onclick="copyToClipboard('markdown-code')" class="absolute top-2 right-2 bg-slate-800 hover:bg-slate-700 text-white px-3 py-1 rounded text-xs opacity-0 group-hover:opacity-100 transition-opacity">
                        Copy
                    </button>
                </div>
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-300 mb-2">HTML</label>
                <div class="bg-slate-950 rounded-xl p-4 overflow-x-auto relative group">
                    <code class="text-sm text-green-400 font-mono" id="html-code">&lt;img src="<%= fullUrl %>" alt="GitHub Stats" /&gt;</code>
                    <button onclick="copyToClipboard('html-code')" class="absolute top-2 right-2 bg-slate-800 hover:bg-slate-700 text-white px-3 py-1 rounded text-xs opacity-0 group-hover:opacity-100 transition-opacity">
                        Copy
                    </button>
                </div>
            </div>
        </div>
    </div>
</main>

<!-- Footer -->
<footer class="border-t border-slate-800 mt-24 bg-card-dark">
    <div class="max-w-7xl mx-auto px-6 py-8 text-center">
        <p class="text-slate-400">Made with ❤️ by <a href="https://pphat.top" class="text-primary hover:underline">pphatdev</a></p>
    </div>
</footer>

<script>
    // Hide loading overlay when image is loaded
    const statsImage = document.getElementById('statsImage');
    const loadingOverlay = document.getElementById('loadingOverlay');
    
    statsImage.addEventListener('load', () => {
        loadingOverlay.classList.add('hidden');
        statsImage.style.opacity = '1';
    });
    
    // If image is already cached and loaded
    if (statsImage.complete) {
        loadingOverlay.classList.add('hidden');
        statsImage.style.opacity = '1';
    }
    
    function copyToClipboard(elementId) {
        const element = document.getElementById(elementId);
        const text = element.textContent;
        navigator.clipboard.writeText(text).then(() => {
            const button = element.parentElement.querySelector('button');
            const originalText = button.textContent;
            button.textContent = 'Copied!';
            setTimeout(() => {
                button.textContent = originalText;
            }, 2000);
        });
    }

    document.getElementById('customizeForm').addEventListener('submit', (e) => {
        e.preventDefault();
        
        // Show loading overlay on image
        const loadingOverlay = document.getElementById('loadingOverlay');
        loadingOverlay.classList.remove('hidden');
        
        const formData = new FormData(e.target);
        const params = new URLSearchParams();
        params.set('username', '<%= username %>');

        for (const [key, value] of formData.entries()) {
            if (key.startsWith('hide_') || key.startsWith('show_')) {
                params.set(key, 'true');
            } else if (value) {
                params.set(key, value);
            }
        }

        // Add unchecked checkboxes as false
        const checkboxes = e.target.querySelectorAll('input[type="checkbox"]');
        checkboxes.forEach(cb => {
            if (!cb.checked) {
                params.set(cb.name, 'false');
            }
        });

        window.location.href = '/stats/view?' + params.toString();
    });
</script>