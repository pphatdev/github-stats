        "url": {
          "raw": "{{baseUrl}}/stats?username=pphatdev&theme=dark",
          "host": ["{{baseUrl}}"],
          "path": ["stats"],
          "query": [
            { "key": "username", "value": "pphatdev" },
            { "key": "theme", "value": "dark" }
          ]
        }
      }
    },
