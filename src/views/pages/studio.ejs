<!-- Design Studio: Figma-inspired layout -->
<div class="min-h-screen bg-background-dark">

    <!-- Header -->
    <header class="border-b border-slate-800/50 bg-card-dark/40 backdrop-blur-sm sticky top-0 z-50">
        <div class="mx-auto px-6 py-2">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <div class="size-10 rounded-xl bg-linear-to-br from-primary/20 to-blue-500/20 flex items-center justify-center border border-primary/30">
                        <span class="material-icons-outlined text-primary">design_services</span>
                    </div>
                    <div>
                        <h1 class="text-xl font-bold text-white">Design Studio</h1>
                        <p class="text-xs text-slate-400">Create & customize SVG cards</p>
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    <button onclick="updatePreview()"  class="button">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-5 w-fit">
                            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                            <path d="M19.933 13.041a8 8 0 1 1 -9.925 -8.788c3.899 -1 7.935 1.007 9.425 4.747" />
                            <path d="M20 4v5h-5" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <div class="p-6">
        <div class="flex flex-row w-full justify-between relative gap-6 overflow-clip">

            <!-- Left Sidebar - Template & Settings -->
            <aside id="leftSidebar" class="flex absolute h-[calc(100vh-8rem)] overflow-y-auto left-0 w-60 shrink-0 z-10 flex-col space-y-4 transition-all duration-300">

                <!-- User Settings -->
                <section class="bg-card-dark/60 p-2 flex overflow-y-auto gap-4 flex-col backdrop-blur-sm rounded-xl border border-slate-800/50">
                    <div class="flex items-center justify-between border-b border-slate-800/50">
                        <h2 class="text-sm font-semibold text-white uppercase tracking-wide flex items-center justify-between gap-2">
                            <span class="material-icons-outlined text-primary text-lg">category</span>
                            <span id="leftSidebarTitle">Templates</span>
                        </h2>
                        <button id="toggleLeftSidebar" class="button px-2! shrink-0" title="Collapse sidebar">
                            <span class="material-icons-outlined text-base">chevron_left</span>
                        </button>
                    </div>
                    <div class="flex gap-4 flex-col">
                        <button data-load-template="stats" class="w-full active p-3 bg-slate-800/50 hover:bg-slate-700/50 border border-slate-700/50 hover:border-primary/50 text-white rounded-lg transition-all duration-200 text-left group">
                            <div class="flex items-center gap-3">
                                <div class="size-8 rounded-lg bg-blue-500/10 flex items-center justify-center group-hover:bg-blue-500/20 transition-colors">
                                    <span class="material-icons-outlined text-blue-400 text-xl">query_stats</span>
                                </div>
                                <div class="flex-1">
                                    <div class="text-sm font-semibold">GitHub Stats</div>
                                    <div class="text-xs text-slate-400">Statistics card</div>
                                </div>
                            </div>
                        </button>

                        <button data-load-template="languages" class="w-full p-3 bg-slate-800/50 hover:bg-slate-700/50 border border-slate-700/50 hover:border-primary/50 text-white rounded-lg transition-all duration-200 text-left group">
                            <div class="flex items-center gap-3">
                                <div class="size-8 rounded-lg bg-purple-500/10 flex items-center justify-center group-hover:bg-purple-500/20 transition-colors">
                                    <span class="material-icons-outlined text-purple-400 text-xl">code</span>
                                </div>
                                <div class="flex-1">
                                    <div class="text-sm font-semibold">Languages</div>
                                    <div class="text-xs text-slate-400">Distribution card</div>
                                </div>
                            </div>
                        </button>
                    </div>
                    <div class="border-b border-slate-800/50">
                        <h2 class="text-sm font-semibold text-white uppercase tracking-wide flex items-center gap-2">
                            <span class="material-icons-outlined text-primary text-lg">tune</span>
                            Card Settings
                        </h2>
                    </div>
                    <div>
                        <div>
                            <label class="block text-xs font-medium text-slate-400 mb-2 uppercase tracking-wide">Username</label>
                            <input type="text"  id="username"  value="pphatdev"  placeholder="GitHub Username"  class="input normal-case">
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-slate-400 mb-2 uppercase tracking-wide">Card Title</label>
                            <input type="text"  id="cardTitle"  value="GitHub Stats"  placeholder="Card Title"  class="input normal-case">
                        </div>

                        <!-- Avatar Mode -->
                        <div>
                            <label class="block text-xs font-medium text-slate-400 mb-2 uppercase tracking-wide">Avatar Mode</label>
                            <select id="avatarMode" class="w-full px-3 py-2.5 text-sm rounded-lg bg-slate-800/50 border border-slate-700/50 text-white focus:border-primary/50 focus:ring-2 focus:ring-primary/20 transition-all">
                                <option value="none">None</option>
                                <option value="avatar">Avatar</option>
                                <option value="radar" selected>Radar</option>
                            </select>
                        </div>

                        <!-- Data Border Style -->
                        <div>
                            <label class="block text-xs font-medium text-slate-400 mb-2 uppercase tracking-wide">Border Style</label>
                            <select id="dataBorderStyle" class="w-full px-3 py-2.5 text-sm rounded-lg bg-slate-800/50 border border-slate-700/50 text-white focus:border-primary/50 focus:ring-2 focus:ring-primary/20 transition-all">
                                <option value="solid">Solid</option>
                                <option value="frame" selected>Frame</option>
                            </select>
                        </div>

                        <!-- Frame Position (shown when frame is selected) -->
                        <div id="framePositionContainer">
                            <label class="block text-xs font-medium text-slate-400 mb-2 uppercase tracking-wide">Frame Position</label>
                            <select id="dataBorderFrame" class="w-full px-3 py-2.5 text-sm rounded-lg bg-slate-800/50 border border-slate-700/50 text-white focus:border-primary/50 focus:ring-2 focus:ring-primary/20 transition-all">
                                <option value="in">Inside</option>
                                <option value="out" selected>Outside</option>
                            </select>
                        </div>

                        <!-- Display Options -->
                        <div class="space-y-2.5">
                            <label class="flex items-center gap-2.5 cursor-pointer group">
                                <input type="checkbox" id="showTitle" checked class="w-4 h-4 rounded border-slate-600 text-primary focus:ring-primary/50">
                                <span class="text-sm text-slate-300 group-hover:text-white transition-colors">Show Title</span>
                            </label>
                            <label class="flex items-center gap-2.5 cursor-pointer group">
                                <input type="checkbox" id="showBorder" checked class="w-4 h-4 rounded border-slate-600 text-primary focus:ring-primary/50">
                                <span class="text-sm text-slate-300 group-hover:text-white transition-colors">Show Border</span>
                            </label>
                            <label class="flex items-center gap-2.5 cursor-pointer group">
                                <input type="checkbox" id="showRank" checked class="w-4 h-4 rounded border-slate-600 text-primary focus:ring-primary/50">
                                <span class="text-sm text-slate-300 group-hover:text-white transition-colors">Show Rank</span>
                            </label>
                        </div>
                    </div>
                </section>
            </aside>

            <!-- Center - Preview -->
            <section class="w-full bg-card-dark/60 p-1 backdrop-blur-sm rounded-2xl border border-slate-800/50">
                <div class="bg-slate-900/50 h-[calc(100vh-8rem)] rounded-xl border border-slate-800/50 flex items-center justify-center overflow-auto"  style="min-height: 600px;"  id="previewContainer">
                    <div id="svgPreview" class="transition-all duration-300 flex items-center justify-center w-full">
                        <!-- SVG will be rendered here -->
                        <div data-empty class="text-center text-slate-400 py-20">
                            <div class="size-20 mx-auto mb-4 rounded-2xl bg-slate-800/50 flex items-center justify-center">
                                <span class="material-icons-outlined text-5xl opacity-30">image</span>
                            </div>
                            <p class="text-sm font-medium">Select a template to preview</p>
                            <p class="text-xs text-slate-500 mt-1">Choose from templates on the left</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Right Sidebar - Customization -->
            <aside id="rightSidebar" class="flex absolute max-h-[calc(100vh-8rem)] overflow-y-auto right-0 w-60 shrink-0 z-10 flex-col transition-all duration-300">
                <!-- Color Customization -->
                <section class="bg-card-dark/60 p-2 flex flex-col backdrop-blur-sm rounded-xl border border-slate-800/50 ">
                    <div class=" flex gap-2 items-center border-b border-slate-800/50">
                        <button id="toggleRightSidebar" class="button px-2!" title="Collapse sidebar">
                            <span class="material-icons-outlined text-base">chevron_right</span>
                        </button>
                        <h2 class="text-sm font-semibold text-white uppercase tracking-wide flex items-center justify-between gap-2">
                            <div class="flex items-center gap-2">
                                <span class="material-icons-outlined text-primary text-lg">palette</span>
                                <span id="rightSidebarTitle">Colors</span>
                            </div>
                        </h2>
                    </div>
                    <div class="flex flex-col gap-4">
                        <!-- Theme Selector -->
                        <div class="flex flex-col gap-2 mt-4 px-2 pt-2">
                            <label class="block text-xs font-medium text-slate-400 uppercase tracking-wide">Theme Preset</label>
                            <select id="themeSelect" class="w-full px-3 py-2.5 text-sm rounded-lg bg-slate-800/50 border border-slate-700/50 text-white focus:border-primary/50 focus:ring-2 focus:ring-primary/20 transition-all">
                                <option value="">Custom</option>
                                <%
                                    const themesList = JSON.parse(themes);
                                    const formatThemeName = (name) => {
                                        return name.split('-').map(word => word.split('_').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')).join(' ');
                                    };
                                    Object.keys(themesList).forEach(themeName => {
                                %>
                                    <option value="<%= themeName %>"><%= formatThemeName(themeName) %></option>
                                <% }); %>
                            </select>
                        </div>

                        <!-- Color Inputs -->
                        <div class="flex flex-col gap-2 px-2">
                            <label class="block text-xs font-medium text-slate-400 uppercase tracking-wide">Background</label>
                            <div class="flex gap-2">
                                <input type="color" id="bgColor" value="#0d1117" class="size-10 shrink-0 rounded-lg cursor-pointer border border-slate-700/50">
                                <input type="text" id="bgColorHex" value="#0d1117" class="input capitalize">
                            </div>
                        </div>
                        <div class="flex flex-col gap-2 px-2">
                            <label class="block text-xs font-medium text-slate-400 uppercase tracking-wide">Border</label>
                            <div class="flex gap-2">
                                <input type="color" id="borderColor" value="#1e293b" class="size-10 shrink-0 rounded-lg cursor-pointer border border-slate-700/50">
                                <input type="text" id="borderColorHex" value="#1e293b" class="input capitalize">
                            </div>
                        </div>
                        <div class="flex flex-col gap-2 px-2">
                            <label class="block text-xs font-medium text-slate-400 uppercase tracking-wide">Text</label>
                            <div class="flex gap-2">
                                <input type="color" id="textColor" value="#ffffff" class="size-10 shrink-0 rounded-lg cursor-pointer border border-slate-700/50">
                                <input type="text" id="textColorHex" value="#ffffff" class="input capitalize">
                            </div>
                        </div>
                        <div class="flex flex-col gap-2 px-2 pb-2">
                            <label class="block text-xs font-medium text-slate-400 uppercase tracking-wide">Accent</label>
                            <div class="flex gap-2">
                                <input type="color" id="accentColor" value="#3b82f6" class="size-10 shrink-0 rounded-lg cursor-pointer border border-slate-700/50">
                                <input type="text" id="accentColorHex" value="#3b82f6" class="input capitalize">
                            </div>
                        </div>
                    </div>
                </section>

            </aside>

        </div>
    </div>

</div>

<script type="application/json" id="users-themes">
    <%- JSON.stringify({
        themes: themes
    }) %>
</script>

<script type="module" src="/js/studio.js"></script>