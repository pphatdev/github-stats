<%- include('../partials/header.ejs') %>

<main class="max-w-7xl mx-auto px-6 py-12" role="main">
    <!-- Hero Section -->
    <div class="bg-linear-to-br from-primary to-blue-700 rounded-4xl p-12 mb-12 text-white">
        <div class="max-w-3xl mx-auto">
            <h2 class="text-4xl font-bold mb-4">Performance Metrics for Your GitHub Profile</h2>
            <p class="text-blue-100 text-lg mb-8">Generate beautiful, customizable SVG cards displaying GitHub user statistics for your README files. Track stars, commits, PRs, and more.</p>

            <!-- Feature Stats Grid -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <div class="bg-white/10 backdrop-blur-sm rounded-2xl px-4 py-3 border border-white/20">
                    <div class="flex items-center gap-2 mb-1">
                        <span class="material-icons-outlined text-lg">palette</span>
                        <p class="text-blue-100 text-xs font-medium">Themes</p>
                    </div>
                    <p class="text-2xl font-bold"><%= themes.length %>+</p>
                </div>
                <div class="bg-white/10 backdrop-blur-sm rounded-2xl px-4 py-3 border border-white/20">
                    <div class="flex items-center gap-2 mb-1">
                        <span class="material-icons-outlined text-lg">speed</span>
                        <p class="text-blue-100 text-xs font-medium">Response Time</p>
                    </div>
                    <p class="text-2xl font-bold">&lt;1s</p>
                </div>
                <div class="bg-white/10 backdrop-blur-sm rounded-2xl px-4 py-3 border border-white/20">
                    <div class="flex items-center gap-2 mb-1">
                        <span class="material-icons-outlined text-lg">cached</span>
                        <p class="text-blue-100 text-xs font-medium">Cache Duration</p>
                    </div>
                    <p class="text-2xl font-bold">10min</p>
                </div>
                <div class="bg-white/10 backdrop-blur-sm rounded-2xl px-4 py-3 border border-white/20">
                    <div class="flex items-center gap-2 mb-1">
                        <span class="material-icons-outlined text-lg">code</span>
                        <p class="text-blue-100 text-xs font-medium">TypeScript</p>
                    </div>
                    <p class="text-2xl font-bold">100%</p>
                </div>
            </div>

            <!-- Feature List -->
            <div class="mt-8 flex justify-center flex-wrap gap-3">
                <div class="flex items-center gap-2 bg-white/10 backdrop-blur-sm rounded-full px-4 py-2 border border-white/20">
                    <span class="material-icons-outlined text-sm">visibility</span>
                    <span class="text-sm font-medium">Live Preview</span>
                </div>
                <div class="flex items-center gap-2 bg-white/10 backdrop-blur-sm rounded-full px-4 py-2 border border-white/20">
                    <span class="material-icons-outlined text-sm">tune</span>
                    <span class="text-sm font-medium">Customizable</span>
                </div>
                <div class="flex items-center gap-2 bg-white/10 backdrop-blur-sm rounded-full px-4 py-2 border border-white/20">
                    <span class="material-icons-outlined text-sm">image</span>
                    <span class="text-sm font-medium">SVG Output</span>
                </div>
                <div class="flex items-center gap-2 bg-white/10 backdrop-blur-sm rounded-full px-4 py-2 border border-white/20">
                    <span class="material-icons-outlined text-sm">sync</span>
                    <span class="text-sm font-medium">Auto-Refresh</span>
                </div>
                <div class="flex items-center gap-2 bg-white/10 backdrop-blur-sm rounded-full px-4 py-2 border border-white/20">
                    <span class="material-icons-outlined text-sm">api</span>
                    <span class="text-sm font-medium">RESTful API</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Demo Section -->
    <div class="grid lg:grid-cols-2 gap-8 mb-12">
        <div class="bg-card-dark rounded-4xl p-8 border border-slate-800 shadow-xl">
            <h3 class="text-2xl font-bold text-white mb-4">Live Demo</h3>
            <p class="text-slate-400 mb-6">See it in action with sample data</p>
            <div class="bg-slate-900 rounded-2xl p-6 flex items-center justify-center relative">
                <img id="demoImage" src="/stats?username=pphatdev&theme=dark" alt="GitHub Stats" class="w-full h-full max-w-full" style="opacity: 0; transition: opacity 0.3s ease-in-out;"/>
                <div id="demoLoadingOverlay" class="absolute inset-0 bg-slate-50/90 dark:bg-slate-900/90 rounded-2xl min-h-full flex items-center justify-center">
                    <div class="text-center">
                        <svg class="animate-spin h-10 w-10 text-primary mx-auto mb-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                        <p class="text-slate-300 font-semibold text-sm">Loading demo...</p>
                    </div>
                </div>
            </div>
            <div class="mt-4">
                <a href="/stats/view?username=pphatdev&theme=dark" class="text-primary hover:text-primary/80 flex items-center justify-center gap-2 text-sm font-semibold">
                    View Full Page
                    <span class="material-icons-outlined text-lg">arrow_forward</span>
                </a>
            </div>
        </div>

        <div class="bg-card-dark rounded-4xl p-8 border border-slate-800 shadow-xl">
            <h3 class="text-2xl font-bold text-white mb-4">Try It Now</h3>
            <p class="text-slate-400 mb-6">Enter your GitHub username to generate your stats card</p>

            <form id="tryItForm" class="space-y-4">
                <div>
                    <label class="block text-sm font-semibold text-slate-300 mb-2">GitHub Username</label>
                    <input type="text" name="username" placeholder="pphatdev" required class="w-full px-4 py-3 rounded-xl bg-slate-800 border border-slate-700 text-white focus:ring-2 focus:ring-primary"/>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-300 mb-2">Theme</label>
                    <select name="theme" class="w-full px-4 py-3 rounded-xl bg-slate-800 border border-slate-700 text-white focus:ring-2 focus:ring-primary">
                        <% themes.forEach(function(themeName) { %>
                            <option value="<%= themeName %>" <%= themeName === 'dark' ? 'selected' : '' %>>
                                <%= themeName.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ') %>
                            </option>
                        <% }); %>
                    </select>
                </div>
                <button type="submit" class="w-full bg-primary hover:bg-primary/90 text-white font-semibold px-6 py-3 rounded-xl transition-colors flex items-center justify-center gap-2">
                    Generate Stats Card
                    <span class="material-icons-outlined">arrow_forward</span>
                </button>
            </form>
        </div>
    </div>

    <!-- Quick Start Section -->
    <div class="bg-card-dark rounded-4xl p-8 border border-slate-800 shadow-xl mb-12">
        <h3 class="text-2xl font-bold text-white mb-4">Quick Start</h3>
        <p class="text-slate-400 mb-6">Add to your GitHub README in seconds</p>

        <div class="space-y-4">
            <div>
                <label class="block text-sm font-semibold text-slate-300 mb-2">Markdown Code</label>
                <div class="bg-slate-900 dark:bg-slate-950 rounded-xl p-4 overflow-x-auto">
                    <code class="text-sm text-blue-400 font-mono">![Stats](stats.sophat.top/stats?username=YOUR_USERNAME)</code>
                </div>
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-300 mb-2">API Endpoint</label>
                <div class="bg-slate-900 dark:bg-slate-950 rounded-xl p-4 overflow-x-auto">
                    <code class="text-sm text-green-400 font-mono">GET /stats?username=YOUR_USERNAME&theme=dark</code>
                </div>
            </div>
        </div>
    </div>

    <!-- Parameters Section (moved here) -->
    <div class="bg-card-dark rounded-4xl p-8 border border-slate-800 shadow-xl mb-12">
        <h3 class="text-2xl font-bold text-white mb-6">API Parameters</h3>
        <div class="grid md:grid-cols-2 gap-4">
            <div class="flex items-start gap-3 p-4 bg-slate-800 rounded-xl">
                <div class="w-8 h-8 flex items-center justify-center bg-primary rounded-lg text-white shrink-0">
                    <span class="material-icons-outlined text-sm">person</span>
                </div>
                <div>
                    <p class="font-semibold text-white">username</p>
                    <p class="text-sm text-slate-400">GitHub username (required)</p>
                </div>
            </div>
            <div class="flex items-start gap-3 p-4 bg-slate-800 rounded-xl">
                <div class="w-8 h-8 flex items-center justify-center bg-primary rounded-lg text-white shrink-0">
                    <span class="material-icons-outlined text-sm">visibility_off</span>
                </div>
                <div>
                    <p class="font-semibold text-white">hide_title</p>
                    <p class="text-sm text-slate-400">Hide the title (true/false)</p>
                </div>
            </div>
            <div class="flex items-start gap-3 p-4 bg-slate-800 rounded-xl">
                <div class="w-8 h-8 flex items-center justify-center bg-primary rounded-lg text-white shrink-0">
                    <span class="material-icons-outlined text-sm">stars</span>
                </div>
                <div>
                    <p class="font-semibold text-white">hide_rank</p>
                    <p class="text-sm text-slate-400">Hide the rank badge (true/false)</p>
                </div>
            </div>
            <div class="flex items-start gap-3 p-4 bg-slate-800 rounded-xl">
                <div class="w-8 h-8 flex items-center justify-center bg-primary rounded-lg text-white shrink-0">
                    <span class="material-icons-outlined text-sm">title</span>
                </div>
                <div>
                    <p class="font-semibold text-white">custom_title</p>
                    <p class="text-sm text-slate-400">Custom card title</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Theme Gallery Section -->
    <div class="bg-card-dark rounded-4xl p-8 border border-slate-800 shadow-xl mb-12">
        <h3 class="text-2xl font-bold text-white mb-4">Theme Gallery</h3>
        <p class="text-slate-400 mb-8">Explore our collection of beautiful themes</p>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% const featuredThemes = ['default', 'dark', 'radical', 'tokyonight', 'dracula', 'monokai', 'gruvbox', 'synthwave', 'cobalt', 'nightowl', 'nord', 'github_dark']; %>
            <% featuredThemes.forEach(function(themeName) { %>
            <div class="group relative bg-slate-800 rounded-xl overflow-hidden border border-slate-700 hover:border-primary transition-all duration-300">
                <div class="aspect-2/1 bg-slate-900 relative overflow-hidden">
                    <img
                        src="/stats?username=pphatdev&theme=<%= themeName %>&avatar_mode=radar&data_border_style=frame&data_border_frame=out"
                        alt="<%= themeName %> theme"
                        class="w-full h-full object-cover"
                        loading="lazy"
                    />
                    <div class="absolute inset-0 bg-linear-to-t from-slate-900 via-transparent to-transparent opacity-60"></div>
                </div>
                <div class="p-4">
                    <div class="flex items-center justify-between">
                        <h4 class="font-semibold text-white capitalize">
                            <%= themeName.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ') %>
                        </h4>
                        <a
                            href="/stats/view?username=pphatdev&theme=<%= themeName %>&avatar_mode=radar&data_border_style=frame&data_border_frame=out"
                            class="text-primary hover:text-primary/80 transition-colors"
                            title="Try this theme"
                        >
                            <span class="material-icons-outlined text-xl">arrow_forward</span>
                        </a>
                    </div>
                    <p class="text-xs text-slate-400 mt-1">Click to customize</p>
                </div>
            </div>
            <% }); %>
        </div>

        <div class="mt-8 text-center">
            <p class="text-slate-400 mb-4">And <%= themes.length - featuredThemes.length %> more themes available!</p>
            <a href="/stats/view?username=pphatdev" class="inline-flex items-center gap-2 bg-slate-800 hover:bg-slate-700 text-white font-semibold px-6 py-3 rounded-xl transition-colors">
                View All <%= themes.length %> Themes
                <span class="material-icons-outlined">palette</span>
            </a>
        </div>
    </div>

    <!-- Examples Section -->
    <div class="bg-card-dark rounded-4xl p-8 border border-slate-800 shadow-xl">
        <h3 class="text-2xl font-bold text-white mb-6">Code Examples</h3>
        <div class="space-y-4">
            <div class="bg-slate-900 dark:bg-slate-950 rounded-xl p-4 overflow-x-auto">
                <code class="text-sm text-purple-400 font-mono">![Stats](https://stats.pphat.top/stats?username=pphatdev&theme=tokyonight&avatar_mode=radar&data_border_style=frame)</code>
            </div>
            <div class="bg-slate-900 dark:bg-slate-950 rounded-xl p-4 overflow-x-auto">
                <code class="text-sm text-pink-400 font-mono">![Stats](https://stats.pphat.top/stats?username=pphatdev&theme=radical&hide_rank=true&avatar_mode=radar&data_border_style=frame)</code>
            </div>
            <div class="bg-slate-900 dark:bg-slate-950 rounded-xl p-4 overflow-x-auto">
                <code class="text-sm text-cyan-400 font-mono">![Stats](https://stats.pphat.top/stats?username=pphatdev&custom_title=My%20GitHub%20Stats&avatar_mode=radar&data_border_style=frame)</code>
            </div>
        </div>
    </div>
</main>

<!-- Footer -->
<footer class="border-t border-slate-800 mt-24 bg-card-dark">
    <div class="max-w-7xl mx-auto px-6 py-8 text-center">
        <p class="text-slate-500 dark:text-slate-400">Made with ❤️ by <a href="https://pphat.top" class="text-primary hover:underline">pphatdev</a></p>
    </div>
</footer>

<script>
    // Hide loading overlay when demo image is loaded
    const demoImage = document.getElementById('demoImage');
    const demoLoadingOverlay = document.getElementById('demoLoadingOverlay');

    demoImage.addEventListener('load', () => {
        demoLoadingOverlay.classList.add('hidden');
        demoImage.style.opacity = '1';
    });

    // If image is already cached and loaded
    if (demoImage.complete) {
        demoLoadingOverlay.classList.add('hidden');
        demoImage.style.opacity = '1';
    }

    document.getElementById('tryItForm').addEventListener('submit', (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        const params = new URLSearchParams();

        for (const [key, value] of formData.entries()) {
            if (value) {
                params.set(key, value);
            }
        }

        window.location.href = '/stats/view?' + params.toString();
    });
</script>